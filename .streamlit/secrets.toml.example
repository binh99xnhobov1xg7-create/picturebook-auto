# ============================================================
#  Streamlit Community Cloud Secrets template (TOML)
#  share.streamlit.io -> App -> Settings -> Secrets
#  See docs/streamlit-cloud-secrets.md for full paste template.
# ============================================================
#
# Cloud setup:
# 1. Open share.streamlit.io, select picturebook-auto app
# 2. Settings -> Secrets, paste TOML, replace placeholders
# 3. Save; redeploy ~3-5 min
# 4. Add user Suqianxue only in Cloud Secrets (not in Git). See docs.
#
[APP_USERS]
teacher1 = "change_me_password"
teacher2 = "change_me_password"

IMAROUTER_API_KEY = "sk-your-imarouter-key"

TEXT_MODEL = "claude-opus-4-7"
EXTRACT_MODEL = "claude-opus-4-7"

IMAGE_MODEL = "gpt-image-2"
IMAGE_SIZE = "1536x1024"

ARK_API_KEY = "ark-your-ark-key"
ARK_BASE_URL = "https://ark.cn-beijing.volces.com/api/v3"
JIMENG_SEEDREAM_MODEL = "doubao-seedream-4-5-251128"
JIMENG_SEEDREAM_SIZE = "2304x1728"

DOUBAO_API_KEY = "ark-your-doubao-or-ark-key"
DOUBAO_MODEL = "doubao-1-5-pro-32k-250115"
DOUBAO_BASE_URL = "https://ark.cn-beijing.volces.com/api/v3"

IMAGE_SELF_REVIEW = "true"
VISION_REVIEW_MODEL = "claude-sonnet-4-6"