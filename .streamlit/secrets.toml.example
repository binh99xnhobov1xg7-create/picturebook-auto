# ============================================================
#  Streamlit Community Cloud · Secrets 模板（TOML 格式）
#  用法：部署后在 share.streamlit.io 的 App -> Settings -> Secrets 里，
#       把下面内容粘进去，并把每个值替换成你本地 .env 里的真实值。
#  ⚠️ 这个 .example 文件只是模板，可以提交到仓库；真实密钥【绝不要】写进仓库。
# ============================================================

# ---- 访问密码（保护网站，只有知道的人能进）----
APP_PASSWORD = "改成你要的密码"

# ---- imarouter 统一 API（文本 + 生图共用同一把 key）----
IMAROUTER_API_KEY = "sk-你的-imarouter-key"

# ---- 文本模型 ----
TEXT_MODEL = "claude-opus-4-7"
EXTRACT_MODEL = "claude-opus-4-7"

# ---- 生图模型 ----
IMAGE_MODEL = "gpt-image-2"
IMAGE_SIZE = "1536x1024"

# ---- 火山方舟 Ark 直连：即梦4.6（仅 L0-2 双模型；不填则自动回退纯 gpt-image-2）----
ARK_API_KEY = "ark-你的-ark-key"
ARK_BASE_URL = "https://ark.cn-beijing.volces.com/api/v3"
JIMENG_SEEDREAM_MODEL = "doubao-seedream-4-5-251128"
JIMENG_SEEDREAM_SIZE = "2304x1728"

# ---- GPT 视觉自审 ----
IMAGE_SELF_REVIEW = "true"
VISION_REVIEW_MODEL = "claude-sonnet-4-6"
