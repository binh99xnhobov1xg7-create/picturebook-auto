# ============ imarouter 统一 API（2026-06-02 迁移）============
# 文本(理解/抽取/出题/润色) + 生图(gpt-image-2) 共用同一把 key
IMAROUTER_API_KEY=
IMAROUTER_BASE=https://api.imarouter.com/v1

# ---- 文本模型 ----
TEXT_MODEL=claude-opus-4-7
EXTRACT_MODEL=claude-sonnet-4-6

# ---- 生图模型（L3-6 主力，也是 L0-2 第二段 GPT 修图）----
IMAGE_MODEL=gpt-image-2
# 绘本正文页：gpt-image-2 出 3:2(1536x1024) → 居中裁 4:3 → 升 4K
IMAGE_SIZE=1536x1024

# ============ 火山方舟 Ark 直连：即梦/Seedream（仅 L0-2 双模型，2026-06-08）============
# L0-2 语义（用户拍板）：即梦【全程出图】= 最终画风；GPT 只做【视觉自审】(IP/多指/图文匹配/分身)，
# 仅当审出硬伤才【定向修图】(图生图保留即梦画风构图)，无问题原样交付即梦图。L3-6 维持纯 gpt-image-2。
# 没填 ARK_API_KEY 时，L0-2 自动回退纯 gpt-image-2（不阻断出图）。
# 控制台→推理接入点→API Key：https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# 即梦 model id（控制台开通后填实际 ID）
JIMENG_SEEDREAM_MODEL=doubao-seedream-4-5-251128
# 即梦 4:3 直出尺寸
JIMENG_SEEDREAM_SIZE=2304x1728
# 可选：全局强制出图后端（gpt / jimeng_refine），留空按 level 自动分流
# IMAGE_BACKEND_OVERRIDE=
# GPT 视觉自审开关 + 多模态模型（本账号 imarouter「vipkid」分组：gpt-4o/gemini 无渠道，用 Claude 系）
IMAGE_SELF_REVIEW=true
VISION_REVIEW_MODEL=claude-sonnet-4-6

# ---- 文本抽取（Doubao，可选；缺省用 imarouter 文本模型）----
DOUBAO_API_KEY=
DOUBAO_MODEL=doubao-1-5-pro-32k-250115
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 调试用：true=不调 API，生成占位图 / 走规则 mock
MOCK_IMAGES=false
MOCK_AI_EXTRACT=false

# 网络请求
REQUEST_TIMEOUT=240
REQUEST_RETRIES=2
