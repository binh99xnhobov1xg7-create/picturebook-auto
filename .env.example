# 火山方舟 / 即梦 4.6 API Key（控制台→推理接入点→API Key）
# https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey
JIMENG_API_KEY=
# 备选别名（二选一）
# ARK_API_KEY=

# 即梦模型 ID（控制台开通 Seedream 4.6 后填实际 ID）
JIMENG_MODEL=doubao-seedream-4-5-251128
JIMENG_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 输出尺寸（4:3）
IMAGE_SIZE=2304x1728
IMAGE_WATERMARK=false

# 调试用：true=不调 API，生成占位图
MOCK_IMAGES=false

# 网络请求
REQUEST_TIMEOUT=240
REQUEST_RETRIES=2
